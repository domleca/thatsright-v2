---
import { getCollection } from 'astro:content';
import GuideLayout from '../../../layouts/GuideLayout.astro';
import { sorted } from '../../../lib/steps';
import { guidePath } from '../../../lib/i18n';

const lang = 'fr';
const steps = await getCollection('steps');
const firstSlug = sorted(steps)[0].data.slug;
---
<GuideLayout lang={lang} title="Guide d'installation — That's Right" path="">
  <section class="landing">
    <p class="eyebrow">Guide d'installation</p>
    <h1>Démarrez en quelques étapes</h1>
    <p class="lede">
      Nous vous guidons pas à pas pour installer l'application et configurer
      le compagnon vocal de votre parent.
    </p>
    <div class="landing-links">
      <a class="btn-primary" href={guidePath(lang, firstSlug)}>Commencer le guide</a>
      <a class="btn-secondary" href={guidePath(lang, 'faq')}>Parcourir les questions</a>
    </div>
  </section>
</GuideLayout>
