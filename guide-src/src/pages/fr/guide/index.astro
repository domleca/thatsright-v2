---
import { getCollection } from 'astro:content';
import GuideLayout from '../../../layouts/GuideLayout.astro';
import { sorted } from '../../../lib/steps';
import { guidePath } from '../../../lib/i18n';

const lang = 'fr';
const steps = await getCollection('steps');
const firstSlug = sorted(steps)[0].data.slug;
---
<GuideLayout lang={lang} title="Guide d'installation — That's Right" path="">
  <section class="landing">
    <p class="eyebrow">Guide d'installation</p>
    <h1>Démarrez en quelques étapes</h1>
    <p class="lede">
      Nous vous guidons pas à pas pour installer l'application et configurer
      le compagnon vocal de votre parent.
    </p>
    <div class="landing-links">
      <a class="btn-primary" href={guidePath(lang, firstSlug)}>Commencer le guide</a>
      <a class="btn-secondary" href={guidePath(lang, 'faq')}>Parcourir les questions</a>
    </div>
  </section>
</GuideLayout>

<style>
  .landing { max-width: 600px; }
  .eyebrow {
    font-size: 12px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 14px;
  }
  h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 36px;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: 18px;
    color: var(--ink);
  }
  .lede {
    font-size: 18px;
    color: var(--ink-soft);
    line-height: 1.6;
    margin-bottom: 32px;
  }
  .landing-links { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn-primary {
    display: inline-block;
    padding: 12px 24px;
    background: var(--terra);
    color: #fff;
    text-decoration: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 500;
  }
  .btn-secondary {
    display: inline-block;
    padding: 12px 24px;
    border: 1px solid var(--line);
    color: var(--ink-soft);
    text-decoration: none;
    border-radius: 8px;
    font-size: 16px;
  }
</style>
