---
import { getCollection } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';
import { sorted } from '../../lib/steps';
import { guidePath } from '../../lib/i18n';

const lang = 'en';
const steps = await getCollection('steps');
const firstSlug = sorted(steps)[0].data.slug;
---
<GuideLayout lang={lang} title="Setup guide — That's Right" path="">
  <section class="landing">
    <p class="eyebrow">Setup guide</p>
    <h1>Get started in a few steps</h1>
    <p class="lede">
      We'll walk you through installing the app and setting up your parent's voice companion,
      one clear step at a time.
    </p>
    <div class="landing-links">
      <a class="btn-primary" href={guidePath(lang, firstSlug)}>Begin the guide</a>
      <a class="btn-secondary" href={guidePath(lang, 'faq')}>Browse questions</a>
    </div>
  </section>
</GuideLayout>

<style>
  .landing { max-width: 600px; }
  .eyebrow {
    font-size: 12px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 14px;
  }
  h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 36px;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: 18px;
    color: var(--ink);
  }
  .lede {
    font-size: 18px;
    color: var(--ink-soft);
    line-height: 1.6;
    margin-bottom: 32px;
  }
  .landing-links { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn-primary {
    display: inline-block;
    padding: 12px 24px;
    background: var(--terra);
    color: #fff;
    text-decoration: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 500;
  }
  .btn-secondary {
    display: inline-block;
    padding: 12px 24px;
    border: 1px solid var(--line);
    color: var(--ink-soft);
    text-decoration: none;
    border-radius: 8px;
    font-size: 16px;
  }
</style>
