---
import { guidePath, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
  prev?: { slug: string; title: { en: string; fr: string } };
  next?: { slug: string; title: { en: string; fr: string } };
}
const { lang, prev, next } = Astro.props;
---
<div class="chevs">
  {prev ? (
    <a class="chev prev" href={guidePath(lang, prev.slug)}>
      <span class="arrow" aria-hidden="true">‹</span>
      <span class="cl">{prev.title[lang]}</span>
    </a>
  ) : <span class="chev spacer"></span>}
  {next ? (
    <a class="chev next" href={guidePath(lang, next.slug)}>
      <span class="cl">{next.title[lang]}</span>
      <span class="arrow" aria-hidden="true">›</span>
    </a>
  ) : <span class="chev spacer"></span>}
</div>
