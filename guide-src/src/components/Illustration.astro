---
import { type Lang } from '../lib/i18n';
import SinglePhone from './SinglePhone.astro';

interface Props { lang: Lang; illustration: { kind: string; [key: string]: any }; bare?: boolean }
const { lang, illustration: ill, bare = false } = Astro.props;
---

{ill.kind === 'two-phone' ? (
  <div class="visual pair">
    <SinglePhone lang={lang} illustration={ill.left} />
    <SinglePhone lang={lang} illustration={ill.right} />
  </div>
) : bare ? (
  <SinglePhone lang={lang} illustration={ill} />
) : (
  <div class="visual">
    <SinglePhone lang={lang} illustration={ill} />
  </div>
)}
